# Copy this file to .env and fill values
# Windows PowerShell:
#   Copy-Item .env.example .env

GITHUB_TOKEN=ghp_your_github_personal_access_token_here
MONGODB_URI=mongodb+srv://username:password@cluster-url/github_trends?retryWrites=true&w=majority

# Use json for stable Windows runs
DATA_SOURCE=json
INCREMENTAL_MODE=false

# Stable run (3-year window)
START_YEAR=2022
END_YEAR=2024
MIN_STARS=50
PER_PAGE=50
MAX_PAGES_PER_YEAR=6
SLEEP_SECONDS=1.0
